<?xml version="1.0" encoding="UTF-8"?>
<Circuit name="PaymentService">
  <Filter name="SetTransactionId" type="SetAttribute">
    <configuration>
      <attribute attributeName="transactionId" value=""/>
    </configuration>
  </Filter>
  <Filter name="RunPaymentScript" type="JavaScriptFilter">
    <script>function processPayment() { return validateCard(); }</script>
  </Filter>
  <Filter name="CallAuth" type="CircuitCall">
    <circuitName>AuthCircuit</circuitName>
  </Filter>
</Circuit>
