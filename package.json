{
  "name": "policy-studio-tools",
  "displayName": "Policy Studio Tools",
  "description": "Tools for Axway Policy Studio projects",
  "version": "0.0.1",
  "publisher": "policy-studio",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Policy Studio",
      "properties": {
        "policyStudio.projects.scanDepth": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "Maximum directory depth below each workspace folder to search for nested Policy Studio projects. 0 = workspace roots only."
        },
        "policyStudio.projects.includePaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["**"],
          "description": "Glob allowlist limiting which paths are scanned for Policy Studio projects."
        },
        "policyStudio.projects.excludePaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/out/**",
            "**/dist/**",
            "**/build/**"
          ],
          "description": "Glob denylist of paths to skip during project discovery."
        },
        "policyStudio.projects.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Enable background discovery of nested Policy Studio projects."
        },
        "policyStudio.circuitSearch.maxResults": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "Maximum number of circuit search results returned per query."
        }
      }
    },
    "commands": [
      {
        "command": "policyStudioTools.placeholder",
        "title": "Policy Studio Tools",
        "category": "Policy Studio"
      },
      {
        "command": "policyStudioTools.selectProjectScope",
        "title": "Select Project Scope",
        "category": "Policy Studio"
      },
      {
        "command": "policyStudioTools.refreshProjects",
        "title": "Refresh Policy Studio Projects",
        "category": "Policy Studio"
      },
      {
        "command": "policyStudioTools.searchCircuits",
        "title": "Search Circuits",
        "category": "Policy Studio"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "policyStudioTools.placeholder",
          "when": "policyStudio.projectDetected"
        },
        {
          "command": "policyStudioTools.searchCircuits",
          "when": "policyStudio.projectDetected"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
